# ===========================================
# Environment Variables for Hotel Web Scraping
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key
SUPABASE_SCHEMA=analysis_hotel

# ===========================================
# CAPTCHA Solving Service
# ===========================================
# Required for automatic CAPTCHA solving
# Supported providers: 2captcha, capsolver
CAPTCHA_API_KEY=your-captcha-api-key
CAPTCHA_PROVIDER=2captcha

# ===========================================
# Managed Proxy Services
# ===========================================
# Used for rotating proxies to avoid blocks
# Supported: scraperapi, scrapingbee, brightdata, oxylabs, smartproxy
SCRAPING_API_KEY=your-proxy-api-key
SCRAPING_API_PROVIDER=scraperapi

# ===========================================
# Manual Proxy Configuration (Alternative)
# ===========================================
# Comma-separated list of proxies in format: server:port:username:password
# CUSTOM_PROXY_LIST=proxy1.com:8080:user:pass,proxy2.com:8080:user:pass

# ===========================================
# BrightData Specific
# ===========================================
# BRIGHTDATA_ZONE=Residential  # Options: Residential, Mobile, ISP, DC

# ===========================================
# Notification Services (Optional)
# ===========================================
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# WHATSAPP_API_KEY=your-whatsapp-api-key
# WHATSAPP_PHONE=your-phone-number

# ===========================================
# Gemini / Claude hybrid LLM configuration
# ===========================================
# For Gemini planning, set a Google API key.
GOOGLE_API_KEY=your-google-api-key
GOOGLE_GEMINI_MODEL=gemini-1.5-pro

# For Claude execution, set an Anthropic API key.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_CLAUDE_MODEL=claude-3.5
